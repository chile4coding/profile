{
  "name": "insighta-backend",
  "version": "1.0.0",
  "description": "Insighta Labs+ Backend - Secure Profile Intelligence Service",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/seed_profiles.json','dist/seed_profiles.json')\"",
    "start": "node dist/server.js",
    "dev": "nodemon",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio dev",
    "prisma:reset": "prisma migrate reset --force",
    "seed": "node dist/seed.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.5",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.6",
    "crypto": "^1.0.1",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.1",
    "tslint": "^6.1.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
